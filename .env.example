# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/finance_tracker"

# Clerk Authentication
CLERK_PUBLISHABLE_KEY="pk_test_your-publishable-key"
CLERK_SECRET_KEY="sk_test_your-secret-key"

# JWT Authentication (Legacy - can be removed after full Clerk migration)
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRATION="7d"

# OpenAI API (for AI features)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Google Cloud Vision API (for receipt OCR)
GOOGLE_VISION_API_KEY="your-google-vision-api-key"

# Gmail OAuth (for email integration)
GMAIL_CLIENT_ID="your-gmail-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/auth/gmail/callback"

# Server Configuration
PORT=3000
NODE_ENV="development"

# Frontend URL
FRONTEND_URL="http://localhost:5173"
