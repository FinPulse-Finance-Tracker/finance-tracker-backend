// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Model
model User {
  id            String   @id @default(uuid())
  clerkId       String?  @unique // Clerk User ID for OAuth users
  email         String   @unique
  passwordHash  String?  // Optional - only for email/password users
  name          String?
  profilePicture String? // Profile picture URL from Clerk/OAuth
  currency      String   @default("LKR")
  monthlyIncome Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categories       Category[]
  expenses         Expense[]
  budgets          Budget[]
  recommendations  AIRecommendation[]
  emailConnections EmailConnection[]

  @@map("users")
}

// Category Model
model Category {
  id           String   @id @default(uuid())
  userId       String?  // Optional for default categories
  name         String
  icon         String?
  color        String?
  budgetAmount Decimal? @db.Decimal(12, 2)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  user            User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  budgets         Budget[]
  recommendations AIRecommendation[]

  @@map("categories")
}

// Expense Model
model Expense {
  id            String   @id @default(uuid())
  userId        String
  categoryId    String?
  amount        Decimal  @db.Decimal(12, 2)
  description   String?
  merchant      String?
  date          DateTime
  paymentMethod String?
  receiptUrl    String?
  isRecurring   Boolean  @default(false)
  source        String?  // 'manual', 'email', 'receipt'
  notes         String?
  emailId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
  @@map("expenses")
}

// Budget Model
model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  period     String   @default("monthly") // 'monthly', 'weekly', 'yearly'
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime @default(now())

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, period])
  @@map("budgets")
}

// AI Recommendation Model
model AIRecommendation {
  id               String   @id @default(uuid())
  userId           String
  categoryId       String?
  type             String   // 'budget', 'merchant', 'savings', 'alternative'
  title            String
  description      String
  savingsPotential Decimal? @db.Decimal(12, 2)
  isDismissed      Boolean  @default(false)
  generatedAt      DateTime @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, isDismissed])
  @@map("ai_recommendations")
}

// Email Connection Model
model EmailConnection {
  id           String    @id @default(uuid())
  userId       String
  emailAddress String
  provider     String    // 'gmail', 'outlook'
  accessToken  String
  refreshToken String
  isActive     Boolean   @default(true)
  lastSynced   DateTime?
  createdAt    DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("email_connections")
}
